# .env

# ====================
# LLM API Keys
# ====================
# Set at least one API key. The system auto-detects available providers and
# selects appropriate default models per role (generation, evaluation, should_run,
# pre_retrieval, embedding). Provider priority when multiple keys are set:
# Anthropic > Gemini > OpenRouter > DeepSeek > MiniMax > DashScope > xAI > Moonshot > ZAI > OpenAI
# For the embedding role, if the top-priority provider has no embedding support,
# the next embedding-capable provider is used (currently OpenAI or Gemini).
# Model resolution order (highest priority first):
#   1. Org-level LLMConfig override
#   2. Non-empty values in reflexio/server/site_var/site_var_sources/llm_model_setting.json
#   3. Auto-detected default for the primary available provider
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=
MINIMAX_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
ZAI_API_KEY=
MOONSHOT_API_KEY=
XAI_API_KEY=

# ====================
# Observability (Optional)
# ====================
# Set to enable Braintrust LLM observability (https://www.braintrust.dev)
# BRAINTRUST_API_KEY=
# BRAINTRUST_PROJECT_NAME=reflexio

# ====================
# Local Storage Configuration
# ====================
# Local storage directory — houses disk-storage artifacts and the SQLite
# database file (reflexio.db). Defaults to ~/.reflexio/data/.
LOCAL_STORAGE_PATH=

# Select the data storage backend. Docker Compose expects Postgres.
# Local CLI defaults to SQLite when unset.
# REFLEXIO_STORAGE=postgres

# Native Postgres storage. Provide a PostgreSQL URL for your database. Startup
# applies deploy/postgres/001-reflexio-setup.sql prerequisites and app migrations
# automatically when needed.
# For Docker Compose talking to a host-exposed local database, use host.docker.internal.
# POSTGRES_DB_URL=postgresql://reflexio:reflexio@host.docker.internal:55432/reflexio
# REFLEXIO_POSTGRES_SCHEMA=public
# REFLEXIO_POSTGRES_POOL_SIZE=5
# REFLEXIO_POSTGRES_SEARCH_BACKEND=postgres

# Optional OpenSearch sidecar for Postgres search. Production AWS deployments
# should use aws_sigv4 auth and provide AWS credentials through the standard
# AWS env/role chain. Local Docker E2E can use auth=none with the test-only
# OpenSearch container from docker-compose.yml.
# REFLEXIO_POSTGRES_SEARCH_BACKEND=opensearch
# REFLEXIO_OPENSEARCH_ENDPOINT=https://search-domain.us-west-2.es.amazonaws.com
# REFLEXIO_OPENSEARCH_AUTH=aws_sigv4
# REFLEXIO_OPENSEARCH_REGION=us-west-2
# REFLEXIO_OPENSEARCH_SERVICE=es
# REFLEXIO_OPENSEARCH_INDEX_PREFIX=reflexio
# REFLEXIO_OPENSEARCH_SYNC_ON_STARTUP=true

# Local OpenSearch E2E example:
# REFLEXIO_POSTGRES_SEARCH_BACKEND=opensearch
# REFLEXIO_OPENSEARCH_ENDPOINT=http://opensearch:9200
# REFLEXIO_OPENSEARCH_AUTH=none

# Optional: use the bundled local embedding path for Docker smoke tests.
# REFLEXIO_EMBEDDING_PROVIDER=inprocess
# CLAUDE_SMART_USE_LOCAL_EMBEDDING=1

# ====================
# Testing & Logging
# ====================
# Set to true to enable test environment mode
IS_TEST_ENV=true
# Set to enable debug logging to console
DEBUG_LOG_TO_CONSOLE=true
# Mock LLM call response
MOCK_LLM_RESPONSE=false
# Override the base directory for log files. The .reflexio/logs suffix is
# always preserved, so e.g. REFLEXIO_LOG_DIR=/tmp/foo writes logs to
# /tmp/foo/.reflexio/logs/. Defaults to $HOME (i.e. ~/.reflexio/logs/).
REFLEXIO_LOG_DIR=
